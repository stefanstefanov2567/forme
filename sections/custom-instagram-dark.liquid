{%- comment -%}
  Custom Instagram (dark banner) — sections/custom-instagram-dark.liquid
  A dark horizontal banner: large IG icon + tag/light heading/subtext on the
  left, a small "OFFICIAL" badge in the middle, and a tight row of 5 square
  sharp-cornered images on the right. Mobile stacks the icon/text and turns the
  images into a horizontal scroller. Texts + 5 images editable. BEM + schema.
{%- endcomment -%}

{%- capture ig_logo -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" xmlns="http://www.w3.org/2000/svg"><rect x="2.5" y="2.5" width="19" height="19" rx="5.5"/><circle cx="12" cy="12" r="4.5"/><circle cx="17.4" cy="6.6" r="1.15" fill="currentColor" stroke="none"/></svg>{%- endcapture -%}
{%- capture mini_icons -%}<svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 21s-7-4.5-7-9.5a3.6 3.6 0 0 1 7-1.3 3.6 3.6 0 0 1 7 1.3C19 16.5 12 21 12 21Z"/></svg><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round" xmlns="http://www.w3.org/2000/svg"><path d="M22 2 11 13"/><path d="M22 2 15 22l-4-9-9-4 20-7Z"/></svg><svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="m12 3 2.5 5.5L20 9l-4 4 1 6-5-3-5 3 1-6-4-4 5.5-.5z"/></svg>{%- endcapture -%}

<section class="ig-dark">
  <div class="ig-dark__inner">
    {%- if section.settings.link != blank -%}
      <a class="ig-dark__logo" href="{{ section.settings.link }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">{{ ig_logo }}</a>
    {%- else -%}
      <span class="ig-dark__logo" aria-hidden="true">{{ ig_logo }}</span>
    {%- endif -%}

    <div class="ig-dark__text">
      {%- if section.settings.top_tag != blank -%}
        <p class="ig-dark__tag">{{ section.settings.top_tag }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="ig-dark__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="ig-dark__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    {%- if section.settings.official_label != blank -%}
      <div class="ig-dark__official">
        <span class="ig-dark__official-icons" aria-hidden="true">{{ mini_icons }}</span>
        <span class="ig-dark__official-label">{{ section.settings.official_label }}</span>
      </div>
    {%- endif -%}

    <div class="ig-dark__images">
      {%- for n in (1..5) -%}
        {%- assign key = 'image_' | append: n -%}
        {%- assign img = section.settings[key] -%}
        <div class="ig-dark__image-item">
          {%- if img != blank -%}
            {{
              img
              | image_url: width: 600
              | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 750px) 7rem, 40vw',
                widths: '200, 320, 440, 600',
                class: 'ig-dark__image',
                alt: section.settings.top_tag
            }}
          {%- else -%}
            {%- capture phn -%}{% cycle 'igdph': 'lifestyle-1', 'lifestyle-2' %}{%- endcapture -%}
            {{ phn | placeholder_svg_tag: 'ig-dark__image ig-dark__image--ph' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .ig-dark {
    background-color: #111111;
    color: #ffffff;
    padding-block: clamp(1.75rem, 3vw, 2.5rem);
    padding-inline: clamp(1.25rem, 4vw, 4rem);
  }

  /* ---------- Mobile: stacked ---------- */
  .ig-dark__inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .ig-dark__logo {
    flex: none;
    display: inline-flex;
    color: #ffffff;
    text-decoration: none;
  }
  .ig-dark__logo svg {
    width: clamp(2.25rem, 4vw, 3rem);
    height: auto;
  }

  .ig-dark__tag {
    margin: 0;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }
  .ig-dark__heading {
    margin: 0.5rem 0 0;
    font-weight: 300;
    line-height: 1.12;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    font-size: clamp(1.35rem, 2.6vw, 1.9rem);
  }
  .ig-dark__subtext {
    margin: 0.55rem 0 0;
    max-width: 42ch;
    font-size: 0.85rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.6);
  }

  .ig-dark__official { display: none; }
  .ig-dark__official-icons {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: rgba(255, 255, 255, 0.7);
  }
  .ig-dark__official-label {
    display: block;
    margin-block-start: 0.5rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }

  .ig-dark__images {
    display: flex;
    width: 100%;
    gap: 4px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .ig-dark__images::-webkit-scrollbar { display: none; }
  .ig-dark__image-item {
    flex: 0 0 auto;
    width: min(40vw, 150px);
    aspect-ratio: 1 / 1;
    overflow: hidden;
    scroll-snap-align: start;
    background-color: #222222;
  }
  .ig-dark__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ig-dark__image--ph { opacity: 0.4; }

  /* ---------- Desktop: single banner row ---------- */
  @media screen and (min-width: 750px) {
    .ig-dark__inner {
      flex-direction: row;
      align-items: center;
      gap: clamp(1.5rem, 3vw, 2.5rem);
    }
    .ig-dark__official {
      display: block;
      flex: none;
      margin-inline-start: auto;
      text-align: center;
    }
    .ig-dark__images {
      display: grid;
      grid-template-columns: repeat(5, clamp(4.5rem, 8vw, 7rem));
      width: auto;
      overflow: visible;
    }
    .ig-dark__image-item { width: auto; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Instagram (dark)",
  "class": "custom-instagram-dark-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "top_tag",
      "label": "Top tag",
      "default": "FOLLOW US"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "ПОСЛЕДВАЙ НИ В INSTAGRAM"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Вдъхновение за движение, баланс и активен начин на живот."
    },
    {
      "type": "text",
      "id": "official_label",
      "label": "Middle label",
      "default": "OFFICIAL"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Instagram link"
    },
    {
      "type": "header",
      "content": "Images"
    },
    { "type": "image_picker", "id": "image_1", "label": "Image 1" },
    { "type": "image_picker", "id": "image_2", "label": "Image 2" },
    { "type": "image_picker", "id": "image_3", "label": "Image 3" },
    { "type": "image_picker", "id": "image_4", "label": "Image 4" },
    { "type": "image_picker", "id": "image_5", "label": "Image 5" }
  ],
  "presets": [
    {
      "name": "Instagram (dark)"
    }
  ]
}
{% endschema %}
