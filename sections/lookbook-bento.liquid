{%- comment -%}
  Lookbook Bento — sections/lookbook-bento.liquid
  Strict 4-block asymmetric bento grid: tall left (rows 1-2), stacked middle
  (top + bottom), tall right (rows 1-2) on desktop; stacks to one column on
  mobile. Each block is an image with one of two text styles. BEM styles +
  schema below.
{%- endcomment -%}

<section
  class="lookbook-bento"
  style="--lb-radius: {{ section.settings.border_radius | default: 24 }}px; --lb-gap: {{ section.settings.gap | default: 8 }}px; --lb-overlay: {{ section.settings.overlay_opacity | default: 30 | divided_by: 100.0 }};"
>
  <div class="lookbook-bento__grid">
    {%- for block in section.blocks -%}
      {%- assign style = block.settings.text_style | default: 'small' -%}
      <div class="lookbook-bento__block lookbook-bento__block--{{ style }}" {{ block.shopify_attributes }}>
        <div class="lookbook-bento__media">
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 1600
              | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 990px) 40vw, 100vw',
                widths: '480, 768, 1024, 1280, 1600',
                class: 'lookbook-bento__image',
                alt: block.settings.image.alt
            }}
          {%- endif -%}
        </div>

        {%- if style == 'large' -%}
          <div class="lookbook-bento__content lookbook-bento__content--large">
            {%- if block.settings.subheading != blank -%}
              <p class="lookbook-bento__subheading">{{ block.settings.subheading }}</p>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h3 class="lookbook-bento__heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="lookbook-bento__text">{{ block.settings.text }}</div>
            {%- endif -%}
            {%- if block.settings.button_label != blank -%}
              <a class="lookbook-bento__button" href="{{ block.settings.button_link | default: '#' }}">{{ block.settings.button_label }}</a>
            {%- endif -%}
          </div>
        {%- else -%}
          <div class="lookbook-bento__content lookbook-bento__content--small">
            {%- if block.settings.heading != blank -%}
              <p class="lookbook-bento__label">{{ block.settings.heading }}</p>
              <span class="lookbook-bento__line" aria-hidden="true"></span>
            {%- endif -%}
          </div>
          {%- if block.settings.button_link != blank -%}
            <a
              class="lookbook-bento__stretched"
              href="{{ block.settings.button_link }}"
              aria-label="{{ block.settings.heading | default: 'View' | escape }}"
            ></a>
          {%- endif -%}
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
  .lookbook-bento {
    padding-inline: clamp(0.75rem, 3vw, 2.5rem);
    padding-block: clamp(1.5rem, 4vw, 3rem);
  }

  /* Grid wrapper: rounded + clipped so the collage corners are perfectly round */
  .lookbook-bento__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--lb-gap, 8px);
    border-radius: var(--lb-radius, 24px);
    overflow: hidden;
  }

  .lookbook-bento__block {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: 400px;
    color: #fff;
    background-color: #262626;
  }

  .lookbook-bento__media {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .lookbook-bento__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Dark overlay for legibility (per style) */
  .lookbook-bento__block::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .lookbook-bento__block--large::after {
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, var(--lb-overlay, 0.3)) 0%,
      rgba(0, 0, 0, calc(var(--lb-overlay, 0.3) * 0.4)) 50%,
      rgba(0, 0, 0, 0) 82%
    );
  }

  .lookbook-bento__block--small::after {
    background: linear-gradient(180deg, rgba(0, 0, 0, var(--lb-overlay, 0.3)) 0%, rgba(0, 0, 0, 0) 55%);
  }

  @media (hover: hover) {
    .lookbook-bento__block:hover .lookbook-bento__image {
      transform: scale(1.04);
    }
  }

  /* ---------- Large: center-left, elegant ---------- */
  .lookbook-bento__content--large {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 1.1rem;
    max-width: 90%;
    padding: clamp(1.5rem, 3vw, 3rem);
  }

  .lookbook-bento__subheading {
    margin: 0;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .lookbook-bento__heading {
    margin: 0;
    font-family: Georgia, "Times New Roman", Times, serif;
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    font-size: clamp(2.2rem, 4vw, 3.75rem);
  }

  .lookbook-bento__text {
    max-width: 30ch;
    font-size: 0.9rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.88);
  }
  .lookbook-bento__text > :first-child { margin-block-start: 0; }
  .lookbook-bento__text > :last-child { margin-block-end: 0; }

  .lookbook-bento__button {
    margin-block-start: 0.5rem;
    display: inline-flex;
    align-items: center;
    padding: 0.85rem 1.5rem;
    background: #fff;
    color: #111;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform 0.25s ease, background-color 0.25s ease;
  }
  @media (hover: hover) {
    .lookbook-bento__button:hover { transform: translateY(-2px); background: #f0efec; }
  }

  /* ---------- Small: top-left label + line ---------- */
  .lookbook-bento__content--small {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.6rem;
    padding: clamp(1.25rem, 2.5vw, 2rem);
  }

  .lookbook-bento__label {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .lookbook-bento__line {
    display: block;
    width: 1.75rem;
    height: 1px;
    background: rgba(255, 255, 255, 0.7);
  }

  .lookbook-bento__stretched {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .lookbook-bento__stretched:focus-visible {
    outline: 2px solid #fff;
    outline-offset: -4px;
  }

  /* ---------- Desktop: strict 4-block asymmetric bento ---------- */
  @media screen and (min-width: 990px) {
    .lookbook-bento__grid {
      grid-template-columns: 1fr 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      min-height: clamp(560px, 72vh, 820px);
    }

    .lookbook-bento__block { min-height: 0; }

    .lookbook-bento__block:nth-child(1) { grid-column: 1; grid-row: 1 / span 2; }
    .lookbook-bento__block:nth-child(2) { grid-column: 2; grid-row: 1; }
    .lookbook-bento__block:nth-child(3) { grid-column: 2; grid-row: 2; }
    .lookbook-bento__block:nth-child(4) { grid-column: 3; grid-row: 1 / span 2; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lookbook-bento__image,
    .lookbook-bento__button {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Lookbook bento",
  "class": "lookbook-bento-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 4,
  "settings": [
    {
      "type": "range",
      "id": "border_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Grid gap",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay",
      "min": 0,
      "max": 70,
      "step": 5,
      "unit": "%",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "block",
      "name": "Image block",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        {
          "type": "select",
          "id": "text_style",
          "label": "Text position / style",
          "options": [
            { "value": "large", "label": "Center left — large (heading + CTA)" },
            { "value": "small", "label": "Top left — small label with line" }
          ],
          "default": "small"
        },
        { "type": "text", "id": "subheading", "label": "Subheading" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "richtext", "id": "text", "label": "Text" },
        { "type": "text", "id": "button_label", "label": "Button label" },
        { "type": "url", "id": "button_link", "label": "Button link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lookbook bento",
      "blocks": [
        {
          "type": "block",
          "settings": {
            "text_style": "large",
            "subheading": "Summer",
            "heading": "State of mind",
            "text": "<p>Light on you. Free in every moment.</p>",
            "button_label": "Shop travel"
          }
        },
        {
          "type": "block",
          "settings": { "text_style": "small", "heading": "Do not disturb" }
        },
        {
          "type": "block",
          "settings": { "text_style": "small" }
        },
        {
          "type": "block",
          "settings": { "text_style": "small", "heading": "Made for anywhere" }
        }
      ]
    }
  ]
}
{% endschema %}
