{%- comment -%}
  Category Showcase — sections/category-showcase.liquid
  Centered header (optional logo, mixed-weight heading via <strong>, subheading)
  + a 5-up card grid that collapses to a horizontal scroll-snap slider below
  large desktop. Each card is a schema block (image, SVG icon, title, desc, link).
  Self-contained: BEM-scoped styles + schema below.
{%- endcomment -%}

<section
  class="category-showcase color-{{ section.settings.color_scheme }}"
  style="--cs-radius: {{ section.settings.card_corner_radius | default: 24 }}px; --cs-logo-width: {{ section.settings.logo_width | default: 120 }}px;"
>
  <div class="category-showcase__header">
    {%- if section.settings.logo != blank -%}
      <div class="category-showcase__logo">
        {{
          section.settings.logo
          | image_url: width: 600
          | image_tag: loading: 'lazy', class: 'category-showcase__logo-image', alt: section.settings.logo.alt | default: shop.name
        }}
      </div>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="category-showcase__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <div class="category-showcase__subheading">{{ section.settings.subheading }}</div>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <ul class="category-showcase__grid" role="list">
      {%- for block in section.blocks -%}
        <li class="category-showcase__item" {{ block.shopify_attributes }}>
          <a
            class="category-showcase__card"
            href="{{ block.settings.link | default: '#' }}"
            {%- if block.settings.title != blank %} aria-label="{{ block.settings.title | escape }}"{% endif %}
          >
            <div class="category-showcase__media">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    sizes: '(min-width: 1200px) 20vw, 78vw',
                    widths: '320, 480, 640, 800, 1000, 1200',
                    class: 'category-showcase__image',
                    alt: ''
                }}
              {%- endif -%}
            </div>

            <div class="category-showcase__top">
              {%- if block.settings.icon != blank -%}
                <span class="category-showcase__icon" aria-hidden="true">{{ block.settings.icon }}</span>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h3 class="category-showcase__title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="category-showcase__desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>

            <span class="category-showcase__arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 12h13m0 0-5-5m5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</section>

{% stylesheet %}
  .category-showcase {
    --cs-gutter: clamp(1.25rem, 4vw, 4rem);

    background-color: var(--color-background, #edebe7);
    color: var(--color-foreground, #1a1a1a);
    padding-block: clamp(3rem, 6vw, 6rem);
    padding-inline: var(--cs-gutter);
  }

  /* ---------- Centered header ---------- */
  .category-showcase__header {
    max-width: 56rem;
    margin-inline: auto;
    margin-block-end: clamp(2.5rem, 5vw, 4rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }

  .category-showcase__logo-image {
    width: var(--cs-logo-width, 120px);
    height: auto;
    object-fit: contain;
  }

  .category-showcase__heading {
    margin: 0;
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    font-size: clamp(1.9rem, 4.6vw, 3.5rem);
    color: rgb(var(--color-foreground-rgb, 26 26 26) / 0.45);
  }

  .category-showcase__heading strong {
    font-weight: 800;
    color: var(--color-foreground, #1a1a1a);
  }

  .category-showcase__subheading {
    max-width: 42rem;
    font-size: 1rem;
    line-height: 1.6;
    color: rgb(var(--color-foreground-rgb, 26 26 26) / 0.7);
  }

  .category-showcase__subheading > :first-child { margin-block-start: 0; }
  .category-showcase__subheading > :last-child { margin-block-end: 0; }

  /* ---------- Grid → mobile/tablet scroll-snap slider ---------- */
  .category-showcase__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    /* let cards bleed to the edge while staying aligned with the content */
    padding-inline: var(--cs-gutter);
    margin-inline: calc(-1 * var(--cs-gutter));
  }

  .category-showcase__grid::-webkit-scrollbar {
    display: none;
  }

  .category-showcase__item {
    flex: 0 0 auto;
    width: min(78vw, 320px);
    scroll-snap-align: start;
  }

  /* ---------- Card ---------- */
  .category-showcase__card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 100%;
    aspect-ratio: 5 / 8;
    padding: 1.5rem;
    border-radius: var(--cs-radius, 24px);
    overflow: hidden;
    isolation: isolate;
    color: #fff;
    text-decoration: none;
    background-color: #2a1f22;
  }

  .category-showcase__media {
    position: absolute;
    inset: 0;
    z-index: -2;
    overflow: hidden;
  }

  .category-showcase__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* dark gradient: darker at top + bottom for text/icon legibility */
  .category-showcase__card::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.6) 0%,
      rgba(0, 0, 0, 0.12) 32%,
      rgba(0, 0, 0, 0.12) 58%,
      rgba(0, 0, 0, 0.68) 100%
    );
  }

  .category-showcase__top {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .category-showcase__icon {
    display: inline-flex;
  }

  .category-showcase__icon svg {
    width: 2rem;
    height: 2rem;
  }

  .category-showcase__title {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .category-showcase__desc {
    margin: 0;
    max-width: 22ch;
    font-size: 0.9rem;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.85);
  }

  .category-showcase__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 50%;
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
  }

  /* ---------- Premium hover ---------- */
  @media (hover: hover) {
    .category-showcase__card:hover .category-showcase__image {
      transform: scale(1.05);
    }

    .category-showcase__card:hover .category-showcase__arrow {
      background-color: #fff;
      color: #111;
      border-color: #fff;
      transform: translateX(2px);
    }
  }

  .category-showcase__card:focus-visible {
    outline: 2px solid var(--color-foreground, #1a1a1a);
    outline-offset: 3px;
  }

  /* ---------- Large desktop: fixed 5-column grid ---------- */
  @media screen and (min-width: 1200px) {
    .category-showcase__grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 1.25rem;
      overflow: visible;
      padding-inline: 0;
      margin-inline: 0;
    }

    .category-showcase__item {
      width: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .category-showcase__image,
    .category-showcase__arrow {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Category showcase",
  "class": "category-showcase-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (optional)"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 40,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 120
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "info": "Bolded words render heavier + darker; the rest is muted.",
      "default": "<strong>Всичко,</strong> от което брандът ти има нужда, за <strong>да расте</strong>"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>В forme създаваме стратегически бранд идентичности, визуални системи и креативни посоки – за да отличим твоя бранд и да постигнем реални резултати.</p>"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "card_corner_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Background image" },
        { "type": "html", "id": "icon", "label": "Icon (inline SVG)", "info": "Paste an inline <svg> using stroke=\"currentColor\" so it stays white." },
        { "type": "text", "id": "title", "label": "Title", "default": "Yoga" },
        { "type": "text", "id": "description", "label": "Description", "default": "Баланс на тялото и ума." },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
