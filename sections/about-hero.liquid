{%- comment -%}
  About Hero — sections/about-hero.liquid
  Two-column hero for the About page: left (~40%) = tag / light uppercase
  heading / thin rule / paragraph / outlined button; right (~60%) = edge-to-edge
  image (object-fit: cover). Stacks on mobile (text over image). All text, the
  button and the image are editable. BEM styles + schema below.
{%- endcomment -%}

<section class="about-hero color-{{ section.settings.color_scheme }}">
  <div class="about-hero__inner">
    <div class="about-hero__content">
      {%- if section.settings.top_tag != blank -%}
        <p class="about-hero__tag">{{ section.settings.top_tag }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="about-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
      <span class="about-hero__rule" aria-hidden="true"></span>
      {%- if section.settings.paragraph != blank -%}
        <div class="about-hero__paragraph">{{ section.settings.paragraph }}</div>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a class="about-hero__button" href="{{ section.settings.button_link | default: '#' }}">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

    <div class="about-hero__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1800
          | image_tag:
            loading: 'eager',
            sizes: '(min-width: 750px) 60vw, 100vw',
            widths: '600, 900, 1200, 1500, 1800',
            class: 'about-hero__image',
            alt: section.settings.heading
        }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'about-hero__image about-hero__image--ph' }}
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .about-hero {
    background-color: var(--color-background, #f4f1ec);
    color: var(--color-foreground, #1a1a1a);
  }

  .about-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
  }

  /* ---------- Left: text ---------- */
  .about-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding: clamp(2.25rem, 6vw, 5rem) clamp(1.25rem, 5vw, 5rem);
  }

  .about-hero__tag {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb, 26 26 26) / 0.55);
  }

  .about-hero__heading {
    margin: 1.1rem 0 0;
    max-width: 14ch;
    font-weight: 300;
    line-height: 1.18;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    font-size: clamp(1.9rem, 3.4vw, 3rem);
  }

  .about-hero__rule {
    display: block;
    width: 3rem;
    height: 1px;
    margin: 1.5rem 0;
    background-color: rgb(var(--color-foreground-rgb, 26 26 26) / 0.4);
  }

  .about-hero__paragraph {
    max-width: 34ch;
    font-size: 0.98rem;
    line-height: 1.7;
    color: rgb(var(--color-foreground-rgb, 26 26 26) / 0.7);
  }
  .about-hero__paragraph > :first-child { margin-block-start: 0; }
  .about-hero__paragraph > :last-child { margin-block-end: 0; }

  .about-hero__button {
    display: inline-flex;
    align-items: center;
    margin-block-start: clamp(1.75rem, 3vw, 2.5rem);
    padding: 0.95rem 2.1rem;
    border: 1px solid rgb(var(--color-foreground-rgb, 26 26 26) / 0.55);
    border-radius: 2px;
    background: transparent;
    color: inherit;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background-color 0.25s ease, color 0.25s ease, border-color 0.25s ease;
  }
  @media (hover: hover) {
    .about-hero__button:hover {
      background-color: var(--color-foreground, #1a1a1a);
      border-color: var(--color-foreground, #1a1a1a);
      color: var(--color-background, #fff);
    }
  }

  /* ---------- Right: image ---------- */
  .about-hero__media {
    position: relative;
    aspect-ratio: 4 / 3;
  }
  .about-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .about-hero__image--ph { opacity: 0.7; }

  /* ---------- Desktop: 40% text + 60% image ---------- */
  @media screen and (min-width: 750px) {
    .about-hero__inner {
      grid-template-columns: 2fr 3fr;
      align-items: stretch;
      min-height: clamp(30rem, 46vw, 42rem);
    }
    .about-hero__media {
      aspect-ratio: auto;
      height: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "About hero",
  "class": "about-hero-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "text",
      "id": "top_tag",
      "label": "Top tag",
      "default": "ЗА НАС"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Създаден за движение. Носен с увереност."
    },
    {
      "type": "richtext",
      "id": "paragraph",
      "label": "Paragraph",
      "default": "<p>FORME е повече от активен стил. Това е начин на живот – баланс между движение, дисциплина и вътрешна сила.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "НАШАТА ИСТОРИЯ"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "presets": [
    {
      "name": "About hero"
    }
  ]
}
{% endschema %}
